@article{theiler_fast_2014,
	title = {Fast registration of laser scans with 4-point congruent sets - what works and what doesn't},
	volume = {II-3},
	issn = {2194-9050},
	url = {http://www.isprs-ann-photogramm-remote-sens-spatial-inf-sci.net/II-3/149/2014/},
	doi = {10.5194/isprsannals-II-3-149-2014},
	abstract = {{\textless}p{\textgreater}Sampling-based algorithms in the mould of RANSAC have emerged as one of the most successful methods for the fully automated registration of point clouds acquired by terrestrial laser scanning (TLS). Sampling methods in conjunction with 3D keypoint extraction, have shown promising results, e.g. the recent K-4PCS (Theiler et al., 2013). However, they still exhibit certain improbable failures, and are computationally expensive and slow if the overlap between scans is low. Here, we examine several variations of the basic K-4PCS framework that have the potential to improve its runtime and robustness. Since the method is inherently parallelizable, straight-forward multi-threading already brings down runtimes to a practically acceptable level (seconds to minutes). At a conceptual level, replacing the RANSAC error function with the more principled MSAC function (Torr and Zisserman, 2000) and introducing a minimum-distance prior to counter the near-field bias reduce failure rates by a factor of up to 4. On the other hand, replacing the repeated evaluation of the RANSAC error function with a voting scheme over the transformation parameters proved not to be generally applicable for the scan registration problem. All these possible extensions are tested experimentally on multiple challenging outdoor and indoor scenarios.{\textless}/p{\textgreater}},
	number = {September},
	journal = {ISPRS Annals of Photogrammetry, Remote Sensing and Spatial Information Sciences},
	author = {Theiler, P. W. and Wegner, J. D. and Schindler, K.},
	year = {2014},
	keywords = {laser scanning, 3d feature extraction, point cloud registration},
	pages = {149--156},
}

@article{yang_automated_2014,
	title = {Automated registration of dense terrestrial laser-scanning point clouds using curves},
	volume = {95},
	issn = {09242716},
	url = {http://dx.doi.org/10.1016/j.isprsjprs.2014.05.012},
	doi = {10.1016/j.isprsjprs.2014.05.012},
	abstract = {This paper proposes an automatic method for registering terrestrial laser scans in terms of robustness and accuracy. The proposed method uses spatial curves as matching primitives to overcome the limitations of registration methods based on points, lines, or patches as primitives. These methods often have difficulty finding correspondences between the scanned point clouds of freeform surfaces (e.g., statues, cultural heritage). The proposed method first clusters visually prominent points selected according to their associated geometric curvatures to extract crest lines which describe the shape characteristics of point clouds. Second, a deformation energy model is proposed to measure the shape similarity of these crest lines to select the correct matching-curve pairs. Based on these pairs, good initial orientation parameters can be obtained, resulting in fine registration. Experiments were undertaken to evaluate the robustness and accuracy of the proposed method, demonstrating a reliable and stable solution for accurately registering complex scenes without good initial alignment. © 2014 International Society for Photogrammetry and Remote Sensing, Inc.},
	journal = {ISPRS Journal of Photogrammetry and Remote Sensing},
	publisher = {International Society for Photogrammetry and Remote Sensing, Inc. (ISPRS)},
	author = {Yang, Bisheng and Zang, Yufu},
	year = {2014},
	keywords = {Feature extraction, Terrestrial laser scanning, Point cloud registration, Curve matching, Deformation energy model, Shape similarity},
	pages = {109--121},
}

