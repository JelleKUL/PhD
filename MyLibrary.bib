@article{kim_automated_2013,
	title = {Automated construction progress measurement using a {4D} building information model and {3D} data},
	volume = {31},
	issn = {09265805},
	url = {http://dx.doi.org/10.1016/j.autcon.2012.11.041 http://linkinghub.elsevier.com/retrieve/pii/S0926580512002361},
	doi = {10.1016/j.autcon.2012.11.041},
	abstract = {Accurate construction progress measurement has been shown to be critical to the success of a building project. However, the methods of automated construction progress measurement proposed in previous studies have certain limitations because of incomplete data sets. The main objective of this research was to develop an accurate, essentially fully automated method for construction progress measurement using a 4D BIM in concert with 3D data obtained by remote-sensing technology. The proposed method consists of three phases: alignment of the as-built data with the as-planned model, matching of the as-built data to information in the BIM, and revision of the as-built status. The accuracy of the proposed construction progress measurement method was validated using 3D data obtained from an actual construction site, thereby demonstrating that construction progress can be effectively measured. The results of the proposed progress measurement methodology can be used as input for construction progress visualization and schedule updating. © 2012 Elsevier B.V. All rights reserved.},
	journal = {Automation in Construction},
	publisher = {Elsevier B.V.},
	author = {Kim, Changmin Changwan and Son, Hyojoo and Kim, Changmin Changwan and Son, Hyojoo},
	month = may,
	year = {2013},
	note = {ISBN: 09265805 (ISSN)},
	keywords = {3D data, Construction automation, 4d building information model, 4D building information model, As-built status revision, construction progress measurement, Construction progress measurement, Keywords},
	pages = {75--82},
}

