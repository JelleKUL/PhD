	volume = {130},
	issn = {09242716},
	doi = {10.1016/j.isprsjprs.2017.06.005},
	abstract = {This paper proposes a method for extracting buildings from LiDAR point cloud data by combining point-based and grid-based features. To accurately discriminate buildings from vegetation, a point feature based on the variance of normal vectors is proposed. For a robust building extraction, a graph cuts algorithm is employed to combine the used features and consider the neighbor contexture information. As grid feature computing and a graph cuts algorithm are performed on a grid structure, a feature-retained DSM interpolation method is proposed in this paper. The proposed method is validated by the benchmark ISPRS Test Project on Urban Classification and 3D Building Reconstruction and compared to the state-art-of-the methods. The evaluation shows that the proposed method can obtain a promising result both at area-level and at object-level. The method is further applied to the entire ISPRS dataset and to a real dataset of the Wuhan City. The results show a completeness of 94.9\% and a correctness of 92.2\% at the per-area level for the former dataset and a completeness of 94.4\% and a correctness of 95.8\% for the latter one. The proposed method has a good potential for large-size LiDAR data.},
	journal = {ISPRS Journal of Photogrammetry and Remote Sensing},
	author = {Du, Shouji and Zhang, Yunsheng and Zou, Zhengrong and Xu, Shenghua and He, Xue and Chen, Siyang},
	year = {2017},
}

@article{wu_graph-based_2017,
	title = {A graph-based approach for 3d building model reconstruction from airborne lidar point clouds},
	volume = {9},
	issn = {20724292},
	doi = {10.3390/rs9010092},
	abstract = {3D building model reconstruction is of great importance for and urban applications. Airborne light detection and (LiDAR) is a very useful data source for acquiring detailed and topological information of building objects. In this, we employed a graph-based method based on hierarchical structure of building contours derived from LiDAR data to reconstruct building models. The proposed approach first uses a graph-based localized contour tree method to represent the topological of buildings, then separates the buildings into different by analyzing their topological relationships, and finally the building model by integrating all the individual models through the bipartite graph matching process. Our approach a more complete topological and geometrical description of contours than existing approaches. We evaluated the proposed by applying it to the Lujiazui region in Shanghai, China, a and large urban scene with various types of buildings. The revealed that complex buildings could be reconstructed with a mean modeling error of 0.32 m. Our proposed method a promising solution for 3D building model reconstruction from LiDAR point clouds.},
	number = {1},
	journal = {Remote Sensing},
	author = {Wu, Bin and Yu, Bailang and Wu, Qiusheng and Yao, Shenjun and Zhao, Feng and Mao, Weiqing and Wu, Jianping},
	year = {2017},
	keywords = {Lidar, Building reconstruction, Graph theory, Bipartite graph matching, Contour tree},
}

