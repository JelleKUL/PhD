	keywords = {Computer Science - Computer Vision and Pattern Recognition, modelnet},
	file = {PDF:C\:\\Users\\jelle\\Zotero\\storage\\2JAWZEMF\\Wu et al. - 2015 - 3D ShapeNets A Deep Representation for Volumetric Shapes.pdf:application/pdf},
