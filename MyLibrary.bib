@misc{de_geyter_scan--bim_2025,
	title = {{SCAN}-to-{BIM} automation of as-built {BIM} production through digitization and machine learning},
	abstract = {The scan-to-BIM process plays a crucial role in the digitalization of the built environment by converting raw point cloud data into structured Building Information Models (BIMs). Despite its potential, this process remains largely manual and labor-intensive, limiting its scalability and efficiency. This thesis proposes a modular and semi-automated approach to address key challenges in data acquisition, semantic segmentation, secondary element detection and BIM enrichment, with a strong focus on improving automation while maintaining accuracy. In the domain of data acquisition, this study evaluates the potential of Indoor Mobile Mapping Systems (IMMS) as an alternative to Terrestrial Laser Scanning (TLS) for scan-to-BIM applications. The findings demonstrate that IMMS significantly reduce data acquisition time, completing data acquisition up to 80\% faster than TLS while still providing point cloud data of sufficient quality for LOA20 and LOD200-350 modeling. Unlike TLS, which requires multiple fixed scanning positions and careful setup planning, IMMS capture point cloud data dynamically while moving, enabling more efficient data collection across large-scale projects. However, challenges such as accumulated drift and increased noise in the point cloud remain. The research highlights the importance of integrating anchor points and loop closures into the SLAM-based IMMS workflow to enhance global accuracy and reduce drift-related errors. Beyond data acquisition, this research addresses the challenge of 3D semantic segmentation, a fundamental step in the automation of scan-to-BIM workflows. One of the key barriers to robust segmentation is the limited availability of real-world training datasets that accurately represent diverse architectural environments. Publicly available datasets are often biased towards specific building types, such as office spaces, and fail to capture the variety of structures encountered in practical scan-to-BIM applications. To mitigate this issue, a novel training data generation pipeline is introduced, allowing for the automated creation of large-scale labeled datasets by leveraging existing BIMs and their corresponding point clouds. The results demonstrate that deep learning models trained using this specific training data exhibit improved segmentation accuracy and generalization on similar environments. For secondary building elements, a two-stage detection and matching approach is proposed to enhance the recognition of elements such as doors and windows. Instead of relying purely on 3D point cloud data, the first detection step utilizes orthographic wall projections to extract 2D representations of secondary elements, which are then processed using state-of-the-art 2D object detection methods. This approach successfully detects door instances, demonstrating the effectiveness of the proposed method. However, the subsequent step of type matching, where detected elements are linked to corresponding BIM object libraries, remains a challenge. Future research should explore these object matching strategies, including the use of enhanced feature-based retrieval methods in existing object libraries. Finally, the study explores the potential of BIM enrichment through automated object detection and localization. A key innovation in this area is the integration of Open-World Object Detection (OWOD), which allows for the identification of both known and previously unseen objects without requiring extensive retraining. By incorporating human language input, the system enables users to define new object categories dynamically, significantly lowering the barrier for integrating diverse elements into BIMs. The results show that specific objects, emergency exit signs, can be detected using this approach and their locations determined with an accuracy of approximately 0.04m. This level of precision is sufficient for facility management applications, allowing for improved asset tracking and safety planning. Moreover, the efficiency of IMMS enables periodic building mapping, ensuring that BIMs can be continuously updated to reflect changes in the built environment. This research advances the field of scan-to-BIM automation by demonstrating how IMMS, semantic segmentation, multi-modal detection techniques and OWOD can contribute to a more scalable and adaptable workflow. While significant progress has been made, key challenges remain, particularly in improving point cloud accuracy, refining object matching methodologies and expanding training datasets to better represent real-world conditions. Addressing these issues in future research will be critical to achieving fully automated and reliable scan-to-BIM processes.},
	language = {eng},
	author = {De Geyter, Sam and Vergauwen, Maarten and Bassier, Maarten},
	month = aug,
	year = {2025},
}

@misc{kerbl_3d_2023,
	title = {{3D} {Gaussian} {Splatting} for {Real}-{Time} {Radiance} {Field} {Rendering}},
	url = {http://arxiv.org/abs/2308.04079},
	doi = {10.48550/arXiv.2308.04079},
	abstract = {Radiance Field methods have recently revolutionized novel-view synthesis of scenes captured with multiple photos or videos. However, achieving high visual quality still requires neural networks that are costly to train and render, while recent faster methods inevitably trade off speed for quality. For unbounded and complete scenes (rather than isolated objects) and 1080p resolution rendering, no current method can achieve real-time display rates. We introduce three key elements that allow us to achieve state-of-the-art visual quality while maintaining competitive training times and importantly allow high-quality real-time ({\textgreater}= 30 fps) novel-view synthesis at 1080p resolution. First, starting from sparse points produced during camera calibration, we represent the scene with 3D Gaussians that preserve desirable properties of continuous volumetric radiance fields for scene optimization while avoiding unnecessary computation in empty space; Second, we perform interleaved optimization/density control of the 3D Gaussians, notably optimizing anisotropic covariance to achieve an accurate representation of the scene; Third, we develop a fast visibility-aware rendering algorithm that supports anisotropic splatting and both accelerates training and allows realtime rendering. We demonstrate state-of-the-art visual quality and real-time rendering on several established datasets.},
	language = {en},
	urldate = {2026-04-03},
	publisher = {arXiv},
	author = {Kerbl, Bernhard and Kopanas, Georgios and Leimkühler, Thomas and Drettakis, George},
	month = aug,
	year = {2023},
