@article{scheer_drywall_2014,
	title = {Drywall {State} {Detection} in {Image} {Data} for {Automatic} {Indoor} {Progress} {Monitoring}},
	issn = {0926-5805},
	url = {y:%5CARCHIV_GEOWATT%5CPaper%5CPaper_archiviert%5CK?nig_1995_Proc_CompuCivilBuildEng_GroundwQualityAssess.PDF},
	doi = {10.1061/9780784413616.053},
	abstract = {ABSTRACT: A 3-dimensional hydrogeochemical transport model is developed by using an iterative sequential approach. The code is designed by coupling a three-dimensional mass transport program and a modified version of PHREEQE [7]. With the physical transport part of the code saturated/ unsaturated transient groundwater flow and mass transport simulations are combined with precipitation-dissolution, oxidation-reduction and ion-exchange reactions governed by chemical'equilibria. Verification of the theoretical approach and of the computer code is done by comparing numerical results to mea-surements of various one -dimensional column tests. In a case study the code is applied in a 3D-field problem in order to predict influences of contaminated water from a dump aquifer in the Lower Rhine brown coal region on the groundwater quality in downstream areas.},
