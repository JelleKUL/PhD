@article{previtali_automatic_2014,
	title = {Automatic façade modelling using point cloud data for energy-efficient retrofitting},
	volume = {6},
	issn = {1866928X},
	doi = {10.1007/s12518-014-0129-9},
	abstract = {Energy-efficient retrofitting of existing buildings is a key aspect for reaching the proposed energy consumption reduction targets fixed by public authorities in different countries. For this task, the availability of as-built building models is of primary importance for both diagnosis of thermal dispersion and designing of retrofitting. In this paper, we present an automated methodology to derive highly detailed 3D vector models of existing building façades starting from terrestrial laser scanning data. The presented methodology first accomplishes the segmentation of the point cloud of a building façade into its planar elements. Then, starting from the identified planar clusters, façade breaklines are automatically extracted to be used later to generate a 3D vector model. During this final step, some priors on urban scenes like the prevalence of straight lines and orthogonal intersections are exploited to set additional constraints. The final product is a semantically enriched 3D model of the building façade that can be integrated in Building Information Model (BIM) for planned maintenance. Eventually, the integration between derived façade models and infrared thermography (IRT) is presented for energy efficiency evaluation of buildings and detection of thermal anomalies. © Società Italiana di Fotogrammetria e Topografia (SIFET) 2011.},
	number = {2},
	journal = {Applied Geomatics},
	author = {Previtali, M. and Barazzetti, L. and Brumana, R. and Cuca, B. and Oreni, D. and Roncoroni, F. and Scaioni, M.},
	year = {2014},
}

