@article{wang_3d_2009,
	title = {{3D} building reconstruction from {LiDAR} data},
	volume = {3980},
	issn = {1062922X},
	url = {http://ieeexplore.ieee.org/lpdocs/epic03/wrapper.htm?arnumber=5345938},
	doi = {10.1109/ICSMC.2009.5345938},
	abstract = {As a fast data acquisition technique, Light Detection and Ranging (LIDAR) can be widely used in many applications, such as visualization, GIS and mobile communication. Since manual surface reconstruction is very costly and time consuming, the development of automated algorithms is of great importance. In this paper a fully automated technique to extract urban building models from LIDAR data is presented. First, LIDAR points are re-sampled into regular grids with the optimal pixel size. After filling holes in the range image, Delaunay Triangulation is utilized to generate 3D triangle meshes. Building height mask is then applied to extract building roof points. Finally, a geometric primitive-based fitting approach is adopted to verify and refine the reconstructed models. The algorithm is tested on two buildings from a locally acquired LIDAR data set. The results indicate that our approach is suitable for automatically producing urban building models from LIDAR data.},
	number = {October},
	journal = {2009 IEEE International Conference on Systems, Man and Cybernetics},
	author = {Wang, Lu and Chu, Chee-hung Henry},
	year = {2009},
	note = {ISBN: 978-1-4244-2793-2},
	keywords = {3d},
	pages = {3054--3059},
}

@article{ibrahim_towards_2009,
	title = {Towards automated progress assessment of workpackage components in construction projects using computer vision},
	volume = {23},
	issn = {14740346},
	url = {http://dx.doi.org/10.1016/j.aei.2008.07.002},
	doi = {10.1016/j.aei.2008.07.002},
	abstract = {Traditional methods of collecting data on the progress of construction projects often involve human judgement, high costs, and are too infrequent to provide managers with timely and accurate control data. This study proposes a system that aims to address some of these shortcomings through automation. Our first contribution is a framework for the automatic generation of work packages. We describe the conceptual model and develop a prototype implementation, based on the results of a survey designed to capture the current practice of formulating work packages as performed in the industry. Our second contribution is a system that employs computer vision (CV) techniques to report on the progress of these work packages automatically. This is achieved by analysing sequences of digital images acquired regularly by on-site cameras. The result of this analysis, when compared with the expected state of construction, provides progress feedback on the work packages, allowing a project to be monitored more effectively. © 2008 Elsevier Ltd. All rights reserved.},
	number = {1},
	journal = {Advanced Engineering Informatics},
	publisher = {Elsevier Ltd},
	author = {Ibrahim, Y. M. and Lukins, T. C. and Zhang, X. and Trucco, E. and Kaka, A. P.},
	year = {2009},
	note = {ISBN: 1474-0346},
	keywords = {Change detection, Computer vision, Progress measurement, Work packaging},
	pages = {93--103},
}

@article{hyyppa_map_2009,
	title = {Map updating and change detection using vehicle-based laser scanning},
	doi = {10.1109/URS.2009.5137682},
	abstract = {The vebicle-based laser scanning (VLS, also known as mobile mapping) a new technology, which is currently under development for creating3D models of the surrounding environment. VLS is based on the integration GPS, IMU, laser scanner and preferably digital cameras mounted top of a moving platform, Le. a car in most applications. VLS a logical development after the first operative Airborne Laser (ALS) in 1994 and Terrestrial Laser Scanners mounted on top a tripod. The data/image processing of VLS are mainly based on of the methods created for ALS and TLS taking into the differences of VLS compared to AILS and TLS. Compared ALS, the geometry of VLS scanning is different and the pulse density as function of range. Two main differences between stationary and constantly moving VLS are the evenness of the data and the. In VLS, the point cloud is evenly distributed along driving direction, and the viewing direction to the target remains In the stop-and-go mode, the data characteristics of the and conventional TLS are similar. A reasonable amount of research been done to develop methods for single-time VLS processing, there have not been any attempts to our knowledge of multitemporal of VLS data. In this paper, the high potential of change based on multitemporal VLS point clouds was demonstrated. cases include the change detection of city models and defoliation city trees. A method to map biomass and biomass change of (city) was developed.},
	journal = {Joint Urban Remote Sensing Event},
	author = {Hyyppä, Juha and Jaakkola, Anttoni and Hyyppä, Hannu and Kaartinen, Harri and Kukko, Antero and Holopainen, Markus and Zhu, Lingli and Vastaranta, Mikko and Kaasalainen, Sanna and Krooks, Anssi and Litkey, Paula and Lyytikäinen-Saarenmaa, Päivi and Matikainen, Leena and Rönnholm, Petri and Chen, Ruizhi and Chen, Yuwei and Kivilahti, Arhi and Kosonen, Iisakki},
	year = {2009},
	note = {ISBN: 9781424434619},
	pages = {0--5},
}

@article{rusu_model-based_2009,
	title = {Model-based and learned semantic object labeling in {3D} point cloud maps of kitchen environments},
	issn = {0006-291X},
	doi = {10.1109/IROS.2009.5354759},
	abstract = {We report on our experiences regarding the acquisition of hybrid Semantic 3D Object Maps for indoor household environments, in particular kitchens, out of sensed 3D point cloud data. Our proposed approach includes a processing pipeline, including geometric mapping and learning, for processing large input datasets and for extracting relevant objects useful for a personal robotic assistant to perform complex manipulation tasks. The type of objects modeled are objects which perform utilitarian functions in the environment such as kitchen appliances, cupboards, tables, and drawers. The resulted model is accurate enough to use it in physics-based simulations, where doors of 3D containers can be opened based on their hinge position. The resulted map is represented as a hybrid concept and is comprised of both the hierarchically classified objects and triangular meshes used for collision avoidance in manipulation routines.},
	number = {November},
	journal = {IEEE/RSJ International Conference on Intelligent Robots and Systems, IROS},
	author = {Rusu, Radu Bogdan and Marton, Zoltan Csaba and Blodow, Nico and Holzbach, Andreas and Beetz, Michael},
