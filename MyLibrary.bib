@article{piaz_stability_2007,
	title = {Stability control of an historical structure with {TLS} survey},
	volume = {Vol. XXXVI},
	abstract = {In this paper we present the preliminary results of a study aimed assess the stability of a complex historical structure such as Anatomy Theatre. The construction occupies the two upper floors the north west side of Palazzo del Bo', the building seat of University of Padua. The Anatomy Theatre is certainly one of oldest, most important and best-known historical “medical” buildings. in 1594, the Theatre was the first permanent structure of its and substituted for the temporary theatres which were set up necessary. The main goal of this work is to verify the stability the time of this kind of structure, given the inherent organic of the wooden parts. Although this task could be performed classical surveying methods, a long-range terrestrial laser (Leica HDS 3000) was employed. This choice was dictated by the numerous measurement benefits offered by TLSs, such three-dimensional data capture, remote and noncontact (i.e. targetless) and dense data acquisition. The presented work is part a wider project aimed not only at the checking of the structure but also at the structural assessment through the use of element model. the paper we will present the preliminary results obtained from repeated checks and highlight issues and difficulties related the laser scanning of an unusual geometry such as the one provided the Anatomy Theatre of the University of Padua.},
	journal = {International Archives of the Photogrammetry, Remote Sensing and Spatial Information Sciences},
	author = {Piaz, V. Dal and Guarnieri, Alberto and Pirotti, F. and Vettore, Antonio},
	year = {2007},
	keywords = {3D modeling, Cultural Heritage, Stability control, Terrestrial Laser Scanning},
}

