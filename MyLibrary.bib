@article{perera_automated_2012,
	title = {an {Automated} {Method} for {3D} {Roof} {Outline} {Generation} and {Regularization} in {Airbone} {Laser} {Scanner} {Data}},
	volume = {I-3},
	issn = {2194-9050},
	url = {http://www.isprs-ann-photogramm-remote-sens-spatial-inf-sci.net/I-3/281/2012/},
	doi = {10.5194/isprsannals-I-3-281-2012},
	abstract = {In this paper, an automatic approach for the generation and regularization of 3D roof boundaries in Airborne Laser scanner data is presented. The workflow is commenced by segmentation of the point clouds. A classification step and a rule based roof extraction step are followed the planar segmentation. Refinement on roof extraction is performed in order to minimize the effect due to urban vegetation. Boundary points of the connected roof planes are extracted and fitted series of straight line segments. Each line is then regularized with respect to the dominant building orientation. We introduce the usage of cycle graphs for the best use of topological information. Ridge-lines and step-edges are basically extracted to recognise correct topological relationships among the roof faces. Inner roof corners are geometrically fitted based on the closed cycle graphs. Outer boundary is reconstructed using the same concept but with the outer most cycle graph. In here, union of the sub cycles is taken. Intermediate line segments (outer bounds) are intersected to reconstruct the roof eave lines. Two test areas with two different point densities are tested with the developed approach. Performance analysis of the test results is provided to demonstrate the applicability of the method.},
	number = {September},
	journal = {ISPRS Annals of Photogrammetry, Remote Sensing and Spatial Information Sciences},
	author = {Perera, S. N. and Nalani, H. A. and Maas, H.-G.},
	year = {2012},
	keywords = {airborne laser scanning, adjacency relationship, planar faces, roof topology graph, shortest closed cycles},
	pages = {281--286},
}

@article{jaboyedoff_use_2012,
	title = {Use of {LIDAR} in landslide investigations: {A} review},
	volume = {61},
	issn = {0921030X},
	doi = {10.1007/s11069-010-9634-2},
	abstract = {This paper presents a short history of the appraisal of laser scannerntechnologies in geosciences used for imaging relief by high-resolutionndigital elevation models (HRDEMs) or 3D models. A general overviewnof light detection and ranging (LIDAR) techniques applied to landslidesnis given, followed by a review of different applications of LIDARnfor landslide, rockfall and debris-flow. These applications are classifiednas: (1) Detection and characterization of mass movements; (2) Hazardnassessment and susceptibility mapping; (3) Modelling; (4) Monitoring.nThis review emphasizes how LIDAR-derived HRDEMs can be used to investigatenany type of landslides. It is clear that such HRDEMs are not yetna common tool for landslides investigations, but this technique has\$nopened new domains of applications that still have to be developed.},
	number = {1},
	journal = {Natural Hazards},
	author = {Jaboyedoff, Michel and Oppikofer, Thierry and Abellán, Antonio and Derron, Marc Henri and Loye, Alex and Metzger, Richard and Pedrazzini, Andrea},
	year = {2012},
	note = {ISBN: 1106901096},
	keywords = {LIDAR, Laser scanner, Structural analysis, High-resolution DEM, Landslide, Topography analysis},
	pages = {5--28},
