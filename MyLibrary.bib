@article{halb_building_2008,
	title = {Building linked data for both humans and machines},
	volume = {369},
	issn = {16130073},
	abstract = {In this paper we describe our experience with building the riese dataset, an interlinked, RDF-based version of the Eu- rostat data, containing statistical data about the European Union. The riese dataset (http://riese.joanneum.at), aims at serving roughly 3 billion RDF triples, along with mil- lions of high-quality interlinks. Our contribution is twofold: Firstly, we suggest using RDFa as the main deployment mechanism, hence serving both humans and machines to effectively and efficiently explore and use the dataset. Sec- ondly, we introduce a new way of enriching the dataset with high-quality links: the User Contributed Interlinking, a Wiki-style way of adding semantic links to data pages.},
