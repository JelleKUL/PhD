	url = {http://download.springer.com/static/pdf/838/bok%3A978-3-642-34234-9.pdf?originUrl=http://link.springer.com/book/10.1007/978-3-642-34234-9&token2=exp=1442764664~acl=/static/pdf/838/bok%253A978-3-642-34234-9.pdf?originUrl=http%3A%2F%2Flink.springer.com%2Fbo},
