@article{grussenmeyer_high_2010,
	title = {High {Resolution} {3D} {Recording} and {Modelling} of the {Bronze} {Age} {Cave} “{Les} {Fraux}” in {Perigord} ({France})},
	volume = {38},
	issn = {2194-9034},
	abstract = {The Bronze Age cave “Les Fraux” at Saint-Martin-de-Fressengeas(Dordogne, France) has been discovered in 1989. This site made of a of galleries of several hundred meters, is a field of for several researchers. This paper will focus on-dimensional contact free measurement techniques for a full3D-documentation of the structural elements of the cave with some focus cave art details. In this cave, most of the art is etched in the clay follows linear, schematic and geometric designs. There are indeed manmade depictions on the walls and other valuable remains of all around the cave. the archaeologists, the documentation and recording started in 2008:- contribute to the accurate indexing of the surveys and images of the and collections as well as structural elements and sculptures;- guarantee the indexing compatibility of the data between the different of researchers involved in the excavation;- ensure the georeferencing of any type of object in the different parts the cave. techniques based on Terrestrial Laser Scanning (FARO Photon80), Digital Photogrammetry (CANON EOS 5D images) and Spatial Imaging (Trimble VX) have been used. The aim of the documentation work is generate a geometric and photorealistic 3D model from the combination point clouds and photogrammetric images, for both visualization and documentation purposes. The underground tunnels of the cave are to the above terrain with surveying techniques for an accurate. The workflow from the raw data to the final PDF-3D model be discussed. Emphasis will also be given to the deliverables, the huge amount of data is not directly usable by the.},
	number = {5},
	journal = {Proceedings of the Isprs Commission V Mid-Term Symposium Close Range Image Measurement Techniques},
	author = {Grussenmeyer, P. and Landes, T. and Alby, E. and Carozza, L.},
	year = {2010},
	keywords = {tls, archaeology, photogrammetry, close range, 3d modelling, caves, documentation, pdf-3d, visualization},
	pages = {262--267},
}

@article{cowley_historic_2010,
	title = {Historic aerial photographs for archaeology and heritage management},
	abstract = {Historic aerial photographs are an invaluable resource for archaeological studies and heritage management. Against this background of change,the view of the past from the 1940s and earlier is increasingly valuable, both as a resource to explore areas that through urban expansion or vegetation change have since been destroyed or obscured, and as a means of assessing changes in condition and context. The value of theseimages as reservoirs of archaeological, economic and social knowledge, and as records of events and changing landscapes, will be illustratedthrough case studies, drawing on imagery held in The Aerial Reconnaissance Archives at RCAHMS, Scotland.},
	number = {August 2009},
	journal = {Space, Time, Place: Third International Conference on Remote Sensing in Archaeology, 17th-21st August 2009,Tiruchirappalli, Tamil Nadu, India.},
	author = {Cowley, Dave and Ferguson, Lesley},
	year = {2010},
	keywords = {aerial photograph archives, historic aerial photographs, landscape change},
	pages = {97--104},
}

@article{bower_blended_2010,
	title = {Blended reality: {Issues} and potentials in combining virtual worlds and face-to-face classes},
	abstract = {This paper describes issues and potentials related to blending virtual worlds and face-to-face environments for the purposes of learning and teaching. By streaming a live video feed of a face-to-face classroom into a virtual world space at the same time as projecting the virtual world space onto a screen in the face-to-face classroom it is possible to merge participation in the two environments. In this way students in remote locations can be offered improved access to and involvement in face-to-face classes, and face-to-face students can capitalise upon the affordances of the virtual world to extend the range of possible learning experiences. A pilot of this technique revealed several potentials for learning and teaching were evident including enhanced remote access to face-to-face classes, increased possibilities for online interaction, and the capacity to leverage the affordances of both worlds within the one learning environment depending on needs. However there were several implementation issues including latency and resolution of the video-stream into the virtual world, the quality of the audio feed, and distorted orientation between face-to-face and virtual world participants. A framework for evaluation is proposed based on an Activity Theory perspective. An invitation for participation in an Australian Learning and Teaching Council grant application is also extended. © 2010 Matthew Bower, Andrew Cram \& Dean Groom.},
	number = {June 2014},
	journal = {ASCILITE 2010 - The Australasian Society for Computers in Learning in Tertiary Education},
	author = {Bower, Matt and Cram, Andrew and Groom, Dean},
	year = {2010},
	note = {ISBN: 9781742720166},
	keywords = {Augmented reality, Augmented virtuality, Blended reality, Learning and teaching spaces, Learning design, Mixed reality, Pedagogy, Technology, Virtual worlds},
	pages = {129--140},
}

